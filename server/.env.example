PORT=5000
MONGO_URI=mongodb://localhost:27017/silentclass
JWT_SECRET=silentclass-secret

# Optional: OpenAI key for AI summaries (text summarization only)
# OPENAI_API_KEY=

# Local transcription (free via faster-whisper)
LOCAL_WHISPER_MODEL=base
LOCAL_WHISPER_COMPUTE_TYPE=int8
LOCAL_WHISPER_DEVICE=cpu
LOCAL_WHISPER_PYTHON_BIN=py
# LOCAL_WHISPER_SCRIPT_PATH=/absolute/path/to/server/scripts/local_whisper_transcribe.py

# 100 MB download cap for remote media URL transcription
MAX_TRANSCRIBE_DOWNLOAD_BYTES=104857600